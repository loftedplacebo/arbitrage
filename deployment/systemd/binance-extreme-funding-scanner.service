[Unit]
Description=Binance extreme-funding independent scanner
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/arbitrage
Environment=PYTHONUNBUFFERED=1
ExecStart=/root/arbitrage/.venv/bin/python -m binance_extreme_funding.run_scanner --loop --interval 60
Restart=always
RestartSec=15
Nice=10

[Install]
WantedBy=multi-user.target
